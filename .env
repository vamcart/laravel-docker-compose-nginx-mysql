# To determine the name of your containers
COMPOSE_PROJECT_NAME=laravel-app

# If you already have the port 8001 in use, you can change it
HOST_MACHINE_UNSECURE_HOST_PORT=8001

MYSQL_HOST_PORT=4306
MYSQL_DOCKER_CONTAINER_PORT=3306
PHP_HOST_PORT=9000
PHP_DOCKER_CONTAINER_PORT=9000

# Xdebug
XDEBUG_LOG_DIR=./logs/xdebug
XDEBUG_PORT=9003
#XDEBUG_PORT=9000